/* pages/order-detail/order-detail.wxss */
page { background: #f8f8f8; }

/* ===== 加载/错误 ===== */
.loading-page { display: flex; flex-direction: column; align-items: center; justify-content: center; height: 80vh; color: #999; font-size: 26rpx; }
.loading-spinner-lg { width: 60rpx; height: 60rpx; border: 4rpx solid #f0f0f0; border-top-color: #ff6b35; border-radius: 50%; animation: spin 0.8s linear infinite; margin-bottom: 20rpx; }
@keyframes spin { to { transform: rotate(360deg); } }
.error-page { display: flex; flex-direction: column; align-items: center; padding-top: 200rpx; color: #999; font-size: 28rpx; }
.error-icon { font-size: 80rpx; margin-bottom: 16rpx; }

/* ===== 状态头部 ===== */
.status-header { padding: 40rpx 32rpx; text-align: center; display: flex; flex-direction: column; align-items: center; }
.status-header.status-pending_pay { background: linear-gradient(135deg, #fff7e6, #ffe7ba); }
.status-header.status-paid { background: linear-gradient(135deg, #f6ffed, #d9f7be); }
.status-header.status-completed { background: linear-gradient(135deg, #e6f7ff, #bae7ff); }
.status-header.status-cancelled { background: linear-gradient(135deg, #f5f5f5, #e8e8e8); }
.status-icon { font-size: 64rpx; margin-bottom: 12rpx; }
.status-title { font-size: 38rpx; font-weight: 700; color: #333; }
.status-hint { font-size: 24rpx; color: #999; margin-top: 8rpx; }

/* ===== 取餐凭证 ===== */
.pickup-section { background: #fff; margin: -16rpx 20rpx 16rpx; border-radius: 16rpx; padding: 32rpx 24rpx; text-align: center; position: relative; z-index: 1; }
.pickup-label { font-size: 26rpx; color: #999; margin-bottom: 16rpx; }
.pickup-code-box { background: #1a1a1a; border-radius: 14rpx; padding: 28rpx 20rpx; margin-bottom: 16rpx; }
.pickup-code { font-size: 56rpx; font-weight: 900; color: #07c160; letter-spacing: 12rpx; font-family: 'Courier New', monospace; }
.pickup-actions { margin-bottom: 12rpx; }
.copy-btn { display: inline-block; padding: 14rpx 40rpx; border-radius: 32rpx; background: #f5f5f5; font-size: 26rpx; color: #666; }
.copy-btn.copied { background: #f6ffed; color: #52c41a; }
.pickup-tip { font-size: 22rpx; color: #ccc; }

/* ===== 通用区块 ===== */
.section { background: #fff; margin: 16rpx 20rpx; border-radius: 16rpx; padding: 24rpx; }
.section-title { font-size: 30rpx; font-weight: 700; color: #333; margin-bottom: 20rpx; padding-left: 16rpx; border-left: 6rpx solid #ff6b35; }

/* 订单信息行 */
.info-row { display: flex; justify-content: space-between; padding: 16rpx 0; border-bottom: 1rpx solid #fafafa; }
.info-row:last-child { border-bottom: none; }
.info-label { font-size: 26rpx; color: #999; flex-shrink: 0; }
.info-value { font-size: 26rpx; color: #333; text-align: right; word-break: break-all; }
.info-value.mono { font-family: monospace; font-size: 24rpx; }
.info-value.orange { color: #ff6b35; font-weight: 600; }

/* 菜品行 */
.item-row { display: flex; align-items: center; padding: 16rpx 0; border-bottom: 1rpx solid #fafafa; }
.item-row:last-child { border-bottom: none; }
.item-img { width: 80rpx; height: 80rpx; border-radius: 10rpx; background: #f5f5f5; margin-right: 14rpx; }
.item-info { flex: 1; }
.item-name { font-size: 28rpx; color: #333; font-weight: 500; }
.item-detail { font-size: 24rpx; color: #999; margin-top: 4rpx; }
.item-subtotal { font-size: 28rpx; color: #333; font-weight: 500; }

/* 价格行 */
.price-row { display: flex; justify-content: space-between; padding: 14rpx 0; font-size: 26rpx; color: #666; }
.price-row.final { border-top: 1rpx solid #f0f0f0; margin-top: 8rpx; padding-top: 20rpx; font-weight: 700; color: #333; }
.price-value { color: #ff6b35; font-size: 34rpx; }

/* ===== 底部操作栏 ===== */
.bottom-bar { position: fixed; bottom: 0; left: 0; right: 0; background: #fff; padding: 16rpx 24rpx; padding-bottom: calc(16rpx + env(safe-area-inset-bottom)); display: flex; gap: 16rpx; box-shadow: 0 -2rpx 16rpx rgba(0,0,0,0.04); z-index: 100; }
.bar-btn { flex: 1; height: 82rpx; line-height: 82rpx; border-radius: 41rpx; font-size: 28rpx; font-weight: 600; text-align: center; border: none; }
.bar-btn::after { border: none; }
.bar-btn.cancel { background: #f5f5f5; color: #666; }
.bar-btn.pay { background: linear-gradient(135deg, #07c160, #06ad56); color: #fff; }
.bar-btn.confirm { background: linear-gradient(135deg, #ff6b35, #ff8c5a); color: #fff; flex: 2; }
.bar-btn.delete { background: #fff; color: #e74c3c; border: 2rpx solid #e74c3c; }
.bar-btn.review { background: linear-gradient(135deg, #ff6b35, #ff8c5a); color: #fff; }
.bar-btn[disabled] { opacity: 0.5; }
.bar-info { flex: 1; text-align: center; line-height: 82rpx; font-size: 28rpx; color: #999; }
