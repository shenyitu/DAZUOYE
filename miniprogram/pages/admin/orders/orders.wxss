page { background: #f8f8f8; }

.tab-bar { background: #fff; padding: 16rpx 20rpx 0; display: flex; gap: 12rpx; overflow-x: auto; white-space: nowrap; position: sticky; top: 0; z-index: 10; }
.tab-item { display: inline-block; padding: 12rpx 24rpx; font-size: 26rpx; color: #666; border-radius: 8rpx 8rpx 0 0; border-bottom: 4rpx solid transparent; flex-shrink: 0; }
.tab-item.active { color: #ff6b35; font-weight: 600; border-bottom-color: #ff6b35; }

.loading-tip { text-align: center; padding: 60rpx; color: #999; font-size: 26rpx; }
.empty-tip { text-align: center; padding: 100rpx 0; color: #ccc; font-size: 28rpx; }

.order-list { padding: 16rpx 20rpx; }
.order-card { background: #fff; border-radius: 14rpx; padding: 24rpx; margin-bottom: 16rpx; }
.order-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12rpx; }
.order-no { font-size: 24rpx; color: #999; font-family: monospace; }
.order-status { font-size: 24rpx; padding: 4rpx 12rpx; border-radius: 6rpx; }
.order-status.pending_pay { background: #fff7e6; color: #fa8c16; }
.order-status.paid { background: #f6ffed; color: #52c41a; }
.order-status.completed { background: #e6f7ff; color: #1890ff; }
.order-status.cancelled { background: #f5f5f5; color: #999; }

.order-user { font-size: 24rpx; color: #666; margin-bottom: 8rpx; }
.order-items { font-size: 24rpx; color: #999; margin-bottom: 12rpx; }
.order-footer { display: flex; justify-content: space-between; align-items: center; }
.order-time { font-size: 22rpx; color: #ccc; }
.order-price { font-size: 30rpx; color: #ff6b35; font-weight: 700; }
