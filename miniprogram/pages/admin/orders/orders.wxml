<view class="container">
  <!-- 状态筛选 -->
  <scroll-view class="tab-bar" scroll-x="true" enhanced show-scrollbar="{{false}}">
    <view wx:for="{{tabs}}" wx:key="key"
          class="tab-item {{currentTab === item.key ? 'active' : ''}}"
          data-tab="{{item.key}}"
          bindtap="switchTab">{{item.label}}</view>
  </scroll-view>

  <view wx:if="{{isLoading}}" class="loading-tip">加载中...</view>
  <view wx:elif="{{isEmpty}}" class="empty-tip">暂无订单</view>

  <view wx:else class="order-list">
    <view wx:for="{{orders}}" wx:key="_id" class="order-card">
      <view class="order-header">
        <text class="order-no">{{item.orderNo}}</text>
        <text class="order-status {{item.status}}">
          {{item.status === 'pending_pay' ? '待支付' : item.status === 'paid' ? '已支付' : item.status === 'completed' ? '已完成' : '已取消'}}
        </text>
      </view>
      <view class="order-user">👤 {{item.userName || '匿名用户'}}</view>
      <view class="order-items">
        <text wx:for="{{item.items}}" wx:for-item="d" wx:key="dishId">{{d.dishName}}×{{d.quantity}} </text>
      </view>
      <view class="order-footer">
        <text class="order-time">{{item.timeText}}</text>
        <text class="order-price">¥{{item.priceText}}</text>
      </view>
    </view>

    <!-- 加载更多 -->
    <view wx:if="{{!hasMore && orders.length > 0}}" style="text-align:center;padding:30rpx 0;color:#ccc;font-size:24rpx;">没有更多了</view>
  </view>
</view>
