page { background: #f8f8f8; }

.container { padding: 30rpx; }

.input-card { background: #fff; border-radius: 16rpx; padding: 32rpx; margin-bottom: 24rpx; }
.input-card .label { font-size: 28rpx; color: #333; font-weight: 600; margin-bottom: 20rpx; display: block; }
.input-row { display: flex; gap: 16rpx; }
.input-row input { flex: 1; height: 80rpx; background: #f8f8f8; border-radius: 12rpx; padding: 0 20rpx; font-size: 32rpx; letter-spacing: 8rpx; }
.input-row .verify-btn { flex-shrink: 0; height: 80rpx; line-height: 80rpx; padding: 0 40rpx; background: linear-gradient(135deg, #07c160, #06ad56); color: #fff; border-radius: 12rpx; font-size: 28rpx; font-weight: 600; border: none; }
.input-row .verify-btn[disabled] { opacity: 0.5; }

.result-card { background: #fff; border-radius: 16rpx; padding: 32rpx; text-align: center; }
.result-icon { font-size: 80rpx; margin-bottom: 16rpx; }
.result-title { font-size: 36rpx; font-weight: 700; margin-bottom: 8rpx; }
.result-title.success { color: #07c160; }
.result-title.fail { color: #e74c3c; }
.result-msg { font-size: 26rpx; color: #999; margin-bottom: 24rpx; }
.result-detail { text-align: left; background: #f8f8f8; border-radius: 12rpx; padding: 24rpx; }
.result-detail .row { display: flex; justify-content: space-between; padding: 10rpx 0; font-size: 26rpx; }
.result-detail .row .lbl { color: #999; }
.result-detail .row .val { color: #333; font-weight: 500; }

.history-section { margin-top: 24rpx; background: #fff; border-radius: 16rpx; padding: 24rpx; }
.history-section .title { font-size: 28rpx; font-weight: 600; color: #333; margin-bottom: 16rpx; }
.history-item { display: flex; justify-content: space-between; align-items: center; padding: 16rpx 0; border-bottom: 1rpx solid #f5f5f5; }
.history-item:last-child { border-bottom: none; }
.history-item .code { font-size: 28rpx; color: #333; font-weight: 600; font-family: monospace; }
.history-item .status { font-size: 24rpx; }
.history-item .status.ok { color: #07c160; }
.history-item .status.fail { color: #e74c3c; }
.history-item .time { font-size: 22rpx; color: #ccc; }
