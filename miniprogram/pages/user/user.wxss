/* pages/user/user.wxss */
.page-container { min-height: 100vh; background: #f8f8f8; }

.no-login { display: flex; flex-direction: column; align-items: center; padding-top: 160rpx; }
.avatar-placeholder { width: 120rpx; height: 120rpx; border-radius: 50%; background: #f0f0f0; display: flex; align-items: center; justify-content: center; font-size: 64rpx; margin-bottom: 24rpx; }
.no-login-text { font-size: 30rpx; color: #999; margin-bottom: 40rpx; }
.login-btn { width: 400rpx; height: 80rpx; line-height: 80rpx; background: #ff6b35; color: #fff; border-radius: 40rpx; font-size: 28rpx; }
.login-btn::after { border: none; }

.user-card { display: flex; align-items: center; background: linear-gradient(135deg, #ff6b35, #ff8c5a); padding: 40rpx 32rpx; margin-bottom: 20rpx; }
.avatar { width: 100rpx; height: 100rpx; border-radius: 50%; border: 4rpx solid rgba(255,255,255,0.4); background: #fff; }
.user-detail { margin-left: 24rpx; }
.nickname { font-size: 36rpx; color: #fff; font-weight: 600; }
.role-tag { margin-top: 8rpx; }
.role-label { font-size: 22rpx; color: rgba(255,255,255,0.8); background: rgba(255,255,255,0.2); padding: 4rpx 16rpx; border-radius: 20rpx; }

.section { background: #fff; margin: 0 20rpx 20rpx; border-radius: 16rpx; overflow: hidden; }
.section-title { font-size: 26rpx; color: #999; padding: 20rpx 24rpx 8rpx; }
.menu-item { display: flex; align-items: center; padding: 24rpx; border-bottom: 1rpx solid #f8f8f8; }
.menu-item:last-child { border-bottom: none; }
.menu-icon { font-size: 36rpx; margin-right: 20rpx; width: 48rpx; text-align: center; }
.menu-info { flex: 1; }
.menu-title { font-size: 28rpx; color: #333; font-weight: 500; }
.menu-desc { font-size: 22rpx; color: #bbb; margin-top: 4rpx; }
.menu-arrow { font-size: 32rpx; color: #ccc; }

.logout-btn { margin: 40rpx 20rpx; height: 88rpx; line-height: 88rpx; text-align: center; background: #fff; border-radius: 16rpx; font-size: 28rpx; color: #e74c3c; }
.version-tip { text-align: center; font-size: 22rpx; color: #ddd; padding: 20rpx 0 40rpx; }
