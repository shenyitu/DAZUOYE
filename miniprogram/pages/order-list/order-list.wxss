/* pages/order-list/order-list.wxss */
.page-container { min-height: 100vh; background: #f8f8f8; }

/* 未登录 */
.no-login { display: flex; flex-direction: column; align-items: center; padding-top: 200rpx; }
.no-login-icon { font-size: 80rpx; margin-bottom: 24rpx; }
.no-login-text { font-size: 30rpx; color: #999; margin-bottom: 40rpx; }
.login-btn { width: 400rpx; height: 80rpx; line-height: 80rpx; background: #ff6b35; color: #fff; border-radius: 40rpx; font-size: 28rpx; }
.login-btn::after { border: none; }

/* 筛选栏 */
.tab-bar { background: #fff; white-space: nowrap; border-bottom: 1rpx solid #f0f0f0; }
.tab-list { display: inline-flex; padding: 16rpx 20rpx; gap: 16rpx; }
.tab-item { padding: 12rpx 32rpx; border-radius: 32rpx; font-size: 26rpx; color: #666; background: #f5f5f5; }
.tab-item.active { background: #fff3ed; color: #ff6b35; font-weight: 600; }

/* 加载与空状态 */
.loading-tip, .empty-tip { text-align: center; padding: 120rpx 0; color: #999; font-size: 28rpx; }
.empty-icon { font-size: 64rpx; margin-bottom: 16rpx; }

/* 订单列表 */
.order-list { padding: 16rpx 20rpx; }
.order-card { background: #fff; border-radius: 16rpx; padding: 24rpx; margin-bottom: 16rpx; }
.order-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.order-no { font-size: 26rpx; color: #333; font-weight: 500; }
.order-status { font-size: 24rpx; padding: 4rpx 16rpx; border-radius: 8rpx; }
.order-status.pending_pay { color: #ff6b35; background: #fff3ed; }
.order-status.paid { color: #1890ff; background: #e6f7ff; }
.order-status.completed { color: #52c41a; background: #f6ffed; }
.order-status.cancelled { color: #999; background: #f5f5f5; }
.order-dishes { font-size: 26rpx; color: #666; margin-bottom: 16rpx; line-height: 1.6; }
.order-footer { display: flex; justify-content: space-between; }
.order-time { font-size: 22rpx; color: #ccc; }
.order-price { font-size: 30rpx; color: #ff6b35; font-weight: 700; }
