/* pages/address/address.wxss */
page { background: #f8f8f8; }

/* ===== 地址列表 ===== */
.address-list { padding: 20rpx; }
.address-card {
  background: #fff; border-radius: 16rpx; padding: 24rpx;
  margin-bottom: 16rpx; position: relative;
}
.address-card.default { border: 2rpx solid #ff6b35; }
.default-badge {
  position: absolute; top: 0; right: 0;
  background: #ff6b35; color: #fff; font-size: 20rpx;
  padding: 4rpx 16rpx; border-radius: 0 16rpx 0 16rpx;
}
.address-name { font-size: 30rpx; font-weight: 600; color: #333; }
.address-phone { font-size: 26rpx; color: #666; margin-left: 16rpx; }
.address-tag {
  font-size: 20rpx; color: #ff6b35; background: #fff3ed;
  padding: 2rpx 12rpx; border-radius: 12rpx; margin-left: 12rpx;
}
.address-detail { font-size: 26rpx; color: #999; margin-top: 8rpx; line-height: 1.5; }
.address-actions {
  display: flex; justify-content: flex-end; gap: 16rpx;
  margin-top: 16rpx; padding-top: 16rpx; border-top: 1rpx solid #f5f5f5;
}
.action-btn {
  font-size: 26rpx; padding: 8rpx 24rpx; border-radius: 20rpx;
  background: #f5f5f5; color: #666;
}
.action-btn.default-btn { color: #ff6b35; background: #fff3ed; }
.action-btn.delete-btn { color: #e74c3c; }

/* ===== 空状态 ===== */
.empty-tip { text-align: center; padding: 160rpx 0; color: #999; font-size: 28rpx; }
.empty-icon { font-size: 80rpx; margin-bottom: 16rpx; }

/* ===== 添加按钮 ===== */
.add-bar {
  position: fixed; bottom: 0; left: 0; right: 0;
  padding: 16rpx 24rpx; padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #fff; box-shadow: 0 -2rpx 16rpx rgba(0,0,0,0.04);
}
.add-btn {
  height: 88rpx; line-height: 88rpx; text-align: center;
  background: #ff6b35; color: #fff; border-radius: 44rpx;
  font-size: 30rpx; font-weight: 600;
}
.add-btn::after { border: none; }

/* ===== 弹窗遮罩 ===== */
.mask {
  position: fixed; inset: 0; background: rgba(0,0,0,0.4);
  z-index: 200;
}
.form-modal {
  position: fixed; bottom: 0; left: 0; right: 0;
  background: #fff; border-radius: 24rpx 24rpx 0 0;
  z-index: 201; padding: 32rpx;
  max-height: 80vh; overflow-y: auto;
}
.form-title { font-size: 34rpx; font-weight: 700; color: #333; margin-bottom: 32rpx; text-align: center; }
.form-group { margin-bottom: 24rpx; }
.form-label { font-size: 26rpx; color: #666; margin-bottom: 8rpx; display: block; }
.form-input {
  width: 100%; height: 72rpx; border: 2rpx solid #eee;
  border-radius: 12rpx; padding: 0 20rpx; font-size: 28rpx;
  box-sizing: border-box;
}
.form-input:focus { border-color: #ff6b35; }
.form-row { display: flex; gap: 16rpx; }
.form-row .form-group { flex: 1; }
.form-btns { display: flex; gap: 16rpx; margin-top: 32rpx; }
.form-btn {
  flex: 1; height: 80rpx; line-height: 80rpx; text-align: center;
  border-radius: 40rpx; font-size: 28rpx; font-weight: 600;
}
.form-btn.cancel { background: #f5f5f5; color: #666; }
.form-btn.submit { background: #ff6b35; color: #fff; }
.form-btn.submit::after, .form-btn.cancel::after { border: none; }

.default-row {
  display: flex; justify-content: space-between; align-items: center;
  padding: 16rpx 0;
}
.default-label { font-size: 28rpx; color: #333; }
