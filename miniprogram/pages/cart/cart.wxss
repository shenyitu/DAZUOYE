/* pages/cart/cart.wxss */
.page-container { min-height: 100vh; background: #f8f8f8; padding-bottom: 120rpx; }

.no-login, .empty-cart { display: flex; flex-direction: column; align-items: center; padding-top: 200rpx; }
.no-login-icon, .empty-icon { font-size: 80rpx; margin-bottom: 24rpx; }
.no-login-text, .empty-text { font-size: 30rpx; color: #999; margin-bottom: 8rpx; }
.empty-sub { font-size: 24rpx; color: #ccc; margin-bottom: 40rpx; }
.login-btn, .go-home-btn { width: 300rpx; height: 80rpx; line-height: 80rpx; background: #ff6b35; color: #fff; border-radius: 40rpx; font-size: 28rpx; }
.login-btn::after, .go-home-btn::after { border: none; }

.cart-list { padding: 16rpx 20rpx; }
.cart-item { display: flex; align-items: center; background: #fff; border-radius: 16rpx; padding: 20rpx 16rpx; margin-bottom: 16rpx; }
.select-btn { padding: 8rpx; }
.select-icon { font-size: 36rpx; }
.item-img { width: 120rpx; height: 120rpx; border-radius: 12rpx; margin: 0 16rpx; background: #f5f5f5; }
.item-info { flex: 1; }
.item-name { font-size: 28rpx; color: #333; font-weight: 500; margin-bottom: 8rpx; }
.item-price { font-size: 30rpx; color: #ff6b35; font-weight: 700; }
.quantity-ctrl { display: flex; align-items: center; gap: 4rpx; margin: 0 12rpx; }
.qty-btn { width: 48rpx; height: 48rpx; border-radius: 50%; background: #f5f5f5; display: flex; align-items: center; justify-content: center; font-size: 28rpx; color: #333; }
.qty-num { width: 56rpx; text-align: center; font-size: 28rpx; font-weight: 600; }
.remove-btn { font-size: 32rpx; padding: 8rpx; }

.bottom-bar { position: fixed; bottom: 0; left: 0; right: 0; background: #fff; padding: 16rpx 24rpx; padding-bottom: calc(16rpx + env(safe-area-inset-bottom)); display: flex; align-items: center; gap: 16rpx; box-shadow: 0 -2rpx 16rpx rgba(0,0,0,0.04); }
.select-all { display: flex; align-items: center; gap: 8rpx; font-size: 26rpx; color: #666; }
.total-info { flex: 1; display: flex; align-items: baseline; }
.total-label { font-size: 26rpx; color: #666; margin-right: 4rpx; }
.total-price { font-size: 36rpx; color: #ff6b35; font-weight: 700; }
.checkout-btn { width: 200rpx; height: 76rpx; line-height: 76rpx; background: #ff6b35; color: #fff; border-radius: 38rpx; font-size: 28rpx; font-weight: 600; }
.checkout-btn::after { border: none; }
.checkout-btn[disabled] { background: #e0e0e0; color: #999; }
